{
  "name": "tmcr-tracker-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "py scripts/extract_tmc_data.py && py scripts/gen_rules.py",
    "predev": "npm run generate",
    "dev": "vite",
    "prebuild": "npm run generate",
    "build": "vite build",
    "build:ci": "vite build",
    "prealpha": "npm run generate",
    "alpha": "vite build --mode alpha",
    "predevbuild": "npm run generate",
    "devbuild": "vite build --mode dev",
    "build:all": "npm run build && npm run alpha && npm run devbuild",
    "all": "npm run build:all && npx serve dist -p 4173",
    "preview": "vite preview",
    "test:e2e": "playwright install && npm run build:ci && playwright test",
    "test:e2e:dev": "playwright install && cross-env DEV=1 playwright test"
  },
  "dependencies": {
    "archipelago.js": "^2.0.4",
    "bootstrap": "^5.3.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.23",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "cross-env": "^10.1.0",
    "vite": "^7.2.1",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
